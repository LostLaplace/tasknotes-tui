Output docs/vhs/output/workflow.gif

Set Shell "bash"
Set Theme "Aardvark Blue"
Set FontSize 16
Set Width 1200
Set Height 900
Set TypingSpeed 0ms

Type "TERM=xterm-256color COLORTERM=truecolor cargo run --bin tasknotes-tui -- --root docs/demo-vault --focus-date 2026-03-29"
Enter
Sleep 1200ms
Type "/review"
Sleep 700ms
Enter
Sleep 700ms
Type " "
Sleep 700ms
Type "S"
Sleep 700ms
Type "q"
Sleep 300ms
